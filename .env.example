# API Keys (choose your provider)
OPENAI_API_KEY=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
REPLICATE_API_TOKEN=your_replicate_token_here

